                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create Teacher User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teacher API Demo\",\n  \"email\": \"teacher.api.demo@openclassy.test\",\n  \"role\": \"teacher\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create user status is 201 or 200', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('created_teacher_id', body.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          }
        },
        {
          "name": "Show Created Teacher (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/{{created_teacher_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "{{created_teacher_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send Message to Teacher (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Mensaje de prueba desde Postman\",\n  \"recipient_ids\": [\n    \"{{created_teacher_id}}\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Send message status 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('sent_message_id', body.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Inbox (Teacher)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Inbox status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (body.data && body.data.length > 0) { pm.collectionVariables.set('inbox_message_id', body.data[0].id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Mark Message As Read (Teacher)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{teacher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/messages/{{inbox_message_id}}/read",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages",
                "{{inbox_message_id}}",
                "read"
              ]
            }
          }
        },
        {
          "name": "Sent Messages (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/messages/sent",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "messages",
                "sent"
              ]
            }
          }
        }
      ]
